[run]
source =
    src
omit =
    */tests/*
    */.eggs/*
    */plugins/*
    */translator_deprecated/*
    src/memento/classifier.py
    src/memento/viewer.py
    src/memento/benchmark/*

[report]
fail_under = 80
exclude_lines =
    pragma: no cover
    def _call_llm_extract
    if __name__ == .__main__.:
    raise NotImplementedError
